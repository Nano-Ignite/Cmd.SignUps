{
  "App": {
    "Version": "1.0.0.0",
    "Apis": {
      "AccountsApi": {
        "Host": "svc-accounts",
        "Root": "api",
        "Port": 8080,
        "UseSsl": false,
        "Timeout": "00:00:30",
        "HealthCheck": {
          "UnhealthyStatus": "Unhealthy"
        }
      },
      "EmailingApi": {
        "Host": "svc-emailing",
        "Root": "api",
        "Port": 8080,
        "UseSsl": false,
        "Timeout": "00:00:30",
        "HealthCheck": {
          "UnhealthyStatus": "Unhealthy"
        }
      }
    }
  },
  "Logging": {
    "LogLevel": "Information",
    "LogLevelOverrides": [
      {
        "Namespace": "Microsoft",
        "LogLevel": "Warning"
      }
    ]
  }
}